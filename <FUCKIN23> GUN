btn("LOAD TACTICAL_AK", UDim2.new(0.05, 0, 0.1, 0), Color3.fromRGB(40, 40, 40), getAK)
btn("EQUIP EXPLOSIVE_VEST", UDim2.new(0.05, 0, 0.3, 0), Color3.fromRGB(80, 0, 0), applyVest)
btn("DETONATE (FATAL)", UDim2.new(0.05, 0, 0.65, 0), Color3.fromRGB(180, 0, 0), detonate)

-- // 5. CORE ENGINE: SHOOT, RECOIL, BLOOD //
mouse.Button1Down:Connect(function()
    local tool = lp.Character and lp.Character:FindFirstChildOfClass("Tool")
    if tool and tool.Name == "AK47_TACTICAL_V4" then
        tool.Handle.Fire:Play()
        
        -- Recoil Kamera
        workspace.CurrentCamera.CFrame = workspace.CurrentCamera.CFrame * CFrame.Angles(math.rad(1.5), math.random(-2,2)/100, 0)
        
        -- Blood Impact Logic
        if mouse.Target and mouse.Target.Parent:FindFirstChild("Humanoid") then
            spawnBlood(mouse.Hit.p)
        end
    end
end)

-- Inf Ammo & No Reload Loop
rs.Heartbeat:Connect(function()
    local tool = lp.Character and lp.Character:FindFirstChildOfClass("Tool")
    if tool then
        for _, v in pairs(tool:GetDescendants()) do
            if (v:IsA("IntValue") or v:IsA("NumberValue")) and (v.Name:lower():find("ammo") or v.Name:lower():find("clip")) then
                v.Value = 999
            end
        end
    end
end)
    
