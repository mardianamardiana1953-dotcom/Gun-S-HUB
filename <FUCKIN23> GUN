-- Setup Toggles
local function setupT(text, pos, key)
    local b = createBtn(text .. ": OFF", pos, Color3.fromRGB(30, 30, 30), function()
        settings[key] = not settings[key]
        _G[key].Text = text .. (settings[key] and ": ON" or ": OFF")
        _G[key].BackgroundColor3 = settings[key] and Color3.fromRGB(0, 120, 0) or Color3.fromRGB(30, 30, 30)
    end)
