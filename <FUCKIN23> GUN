game:GetService("RunService").RenderStepped:Connect(function()
    local t = lp.Character and lp.Character:FindFirstChildOfClass("Tool")
    if t then
        if settings.InfAmmo or settings.NoReload then
            for _, v in pairs(t:GetDescendants()) do
                if (v:IsA("IntValue") or v:IsA("NumberValue")) and (v.Name:lower():find("ammo") or v.Name:lower():find("clip")) then
                    v.Value = 999
                end
            end
        end
        if settings.NoRecoil then
            local r = t:FindFirstChild("Recoil") or t:FindFirstChild("Shake")
            if r then r.Disabled = true end
        end
    end
end)

