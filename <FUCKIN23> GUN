-- === 1. FITUR SUARA TEMBAKAN (REALISTIC SOUND) ===
local function playGunSound(tool)
    -- Mencari suara tembakan di dalam tool, jika tidak ada pakai ID Universal
    local sound = tool:FindFirstChild("Fire") or tool:FindFirstChild("Shoot") or tool:FindFirstChildOfClass("Sound")
    
    if not sound then
        sound = Instance.new("Sound", tool.Handle)
        sound.Name = "RealisticFire"
        sound.SoundId = "rbxassetid://330706792" -- ID Suara Tembakan Militer Universal
        sound.Volume = 2
    end
    sound:Play()
end

-- === 2. FITUR ROMPI BOMB (SUICIDE VEST) ===
local function equipVest()
    pcall(function()
        local model = InsertService:LoadAsset(vestID)
        local vest = model:FindFirstChildOfClass("Accessory") or model:FindFirstChildOfClass("Model")
        if vest then
            vest.Parent = lp.Character
            print("[✔] Suicide Vest Equipped")
        end
        model:Destroy()
    end)
end

local function explodeSelf()
    if not lp.Character or not lp.Character:FindFirstChild("HumanoidRootPart") then return end
    
    local pos = lp.Character.HumanoidRootPart.Position
    local exp = Instance.new("Explosion", workspace)
    exp.Position = pos
    exp.BlastRadius = 30
    exp.BlastPressure = 1000000
    
    -- Suara Ledakan Besar
    local s = Instance.new("Sound", workspace)
    s.SoundId = "rbxassetid://142070127"
    s.Volume = 5
    s:Play()

    lp.Character.Humanoid.Health = 0
end

